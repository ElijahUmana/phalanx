# Phalanx environment. Copy to .env.local and fill in. .env.local is gitignored.

# --- Coordination layer (required) ---
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# --- Web agent + publication (required) ---
TINYFISH_API_KEY=sk-tinyfish-...
SENSO_API_KEY=tgr_...

# --- Per-hypothesis staging backends (Task #6) ---
INSFORGE_API_KEY=

# --- x402 payments + CDP wallet (Task #7) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# --- GitHub PR creation (Task #5) ---
GITHUB_TOKEN=

# --- LLM + embeddings (Tasks #3, #4 use embeddings; #8 uses LLM) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Nexla writeback (Task #10). Optional — if unset, writeback is logged only. ---
NEXLA_SLACK_WEBHOOK_URL=

# --- Ghost ---
# ghost login is already authenticated at the CLI level; the DB name is referenced here.
GHOST_DB_NAME=phalanx-deps

# --- Embedding config (must match across Ghost pgvector + Redis Vector Sets) ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

NODE_ENV=development
